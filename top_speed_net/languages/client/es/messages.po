#: D:\top_speed\top_speed_net\TopSpeed\Menu\registry\options\Volume.cs:33
msgid ""
"Controls engine-related sounds for bots and other players, including engine "
"start and stop."
msgstr ""
"Controla los sonidos relacionados con el motor para bots y otros jugadores, "
"incluido el arranque y la parada del motor."

#: D:\top_speed\top_speed_net\TopSpeed\Menu\registry\options\Volume.cs:28
msgid ""
"Controls events related to your own vehicle, such as horn, back-fire, and "
"other vehicle events."
msgstr ""
"Controla eventos relacionados con su propio vehículo, como bocina, petardeo "
"del escape y otros eventos del vehículo."

#: D:\top_speed\top_speed_net\TopSpeed\Menu\registry\options\Volume.cs:38
msgid ""
"Controls horns, crashes, bumps, brakes, and similar event sounds for bots "
"and other players."
msgstr ""
"Controla bocinas, choques, golpes, frenos y sonidos de eventos similares "
"para bots y otros jugadores."

#: D:\top_speed\top_speed_net\TopSpeed\Menu\registry\options\Volume.cs:62
msgid ""
"Controls menu and race music volume. This stays synchronized with the menu "
"music volume setting."
msgstr ""
"Controla el menú y el volumen de la música de carrera. Esto permanece "
"sincronizado con la configuración del volumen de música del menú."

#: D:\top_speed\top_speed_net\TopSpeed\Menu\registry\options\Volume.cs:48
msgid ""
"Controls radio playback volume from other players only. Your own radio "
"playback is not affected."
msgstr ""
"Controla el volumen de reproducción de radio únicamente de otros "
"reproductores. La reproducción de su propia radio no se ve afectada."

#: D:\top_speed\top_speed_net\TopSpeed\Menu\registry\options\Volume.cs:43
msgid "Controls road and surface loops like asphalt, gravel, etc."
msgstr ""
"Controla los circuitos de carreteras y superficies como asfalto, grava, etc."

#: D:\top_speed\top_speed_net\TopSpeed\Menu\registry\options\Volume.cs:67
msgid ""
"Controls server and multiplayer event sounds such as connection and other "
"events."
msgstr ""
"Controla los sonidos de eventos del servidor y multijugador, como conexiones "
"y otros eventos."

#: D:\top_speed\top_speed_net\TopSpeed\Menu\registry\options\Volume.cs:18
msgid ""
"Controls the overall audio volume for the game. Set lower to reduce every "
"sound category."
msgstr ""
"Controla el volumen de audio general del juego. Configúrelo más bajo para "
"reducir cada categoría de sonido."

#: D:\top_speed\top_speed_net\TopSpeed\Menu\registry\options\Volume.cs:53
msgid ""
"Controls track ambients, weather loops, noise sounds, and custom track sound "
"sources."
msgstr ""
"Controla los ambientes de las pistas, los bucles meteorológicos, los sonidos "
"de ruido y las fuentes de sonido de las pistas personalizadas."

#: D:\top_speed\top_speed_net\TopSpeed\Menu\registry\options\Volume.cs:23
msgid ""
"Controls your own engine and throttle sounds, including engine start and "
"stop."
msgstr ""
"Controla su propio motor y los sonidos del acelerador, incluido el arranque "
"y la parada del motor."

